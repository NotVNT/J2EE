{
  "expo": {
    "name": "Devbot",
    "slug": "moneymanager-mobile",
    "scheme": "moneymanager",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "jsEngine": "hermes",
    "icon": "./src/assets/devbot_logo_app.png",
    "splash": {
      "image": "./src/assets/devbot_logo_app.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.moneymanager.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/devbot_logo_app.png",
        "backgroundColor": "#ffffff"
      }
    },
    "ios": {
      "bundleIdentifier": "com.moneymanager.mobile",
      "icon": "./src/assets/devbot_logo_app.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "d4c3e013-5223-4605-982d-cd283c786fe1"
      }
    }
  }
}
